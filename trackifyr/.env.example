# PostgreSQL connection string (required for auth API routes).
# Local example (matches Docker command in README if you use it):
DATABASE_URL=postgresql://postgres:trackifyr@localhost:5432/trackifyr

# Optional: force TLS for pg (cloud DBs often auto-detected from the URL).
# DATABASE_SSL=true
# Local Postgres without TLS:
# DATABASE_SSL=false

# /download uses (in order): NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL, else public/releases/trackifyr-desktop-setup.exe or .zip, else GitHub latest .exe (no env needed).
# Override GitHub installer URL (forks or new desktop tag): NEXT_PUBLIC_DESKTOP_GITHUB_EXE=https://github.com/ORG/REPO/releases/download/desktop-v1.0.0/trackifyr-Setup-1.0.0.exe
# Hide GitHub fallback (show setup instructions only): NEXT_PUBLIC_DESKTOP_DOWNLOAD_DISABLE_GITHUB=1
# Force any URL (e.g. ZIP): NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=https://...
