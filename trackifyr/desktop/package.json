{
  "name": "trackifyr-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "trackifyr desktop session client",
  "author": "trackifyr",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "predist": "node ./scripts/clean-release.js",
    "write-release-config": "node ./scripts/write-release-config.js",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false node ./node_modules/electron-builder/cli.js --win --x64"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.trackifyr.desktop",
    "productName": "trackifyr",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "fusion.js",
      "tracking-bridge.js",
      "renderer/**/*",
      "release-config.json"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "python-tracking",
        "filter": [
          "activity_tracker.py",
          "webcam_cognitive_load.py",
          "ml/**/*"
        ]
      }
    ],
    "win": {
      "sign": null,
      "signAndEditExecutable": false,
      "signDlls": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  }
}
